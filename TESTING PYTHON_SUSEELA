name = "SUSEELA"
age = 30
height = 4.8
is_student = True

# Print all values in one print statement
print(name, age, height, is_student)

# Task 2: String Formatting
print(f"Name: {name} | Age: {age} | Height: {height} | Student: {is_student}")

# Task 3: Arithmetic Operations
age_in_months = age * 12
age_in_days = age * 365
remainder = age % 7
age_squared = age ** 2

print("Age in months:", age_in_months)
print("Age in days:", age_in_days)
print("Age % 7:", remainder)
print("Age squared:", age_squared)